---
import { STATS } from '@/config/site';
---

<section
  id="problem"
  class="relative py-20 lg:py-32 bg-gradient-to-b from-white to-gray-50 overflow-hidden"
>
  <!-- Background decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-100/30 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-accent-blue/10 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 lg:mb-20" data-animate>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-brand-dark-purple mb-4">
          The Supply Travelers Want is Nowhere to be Found
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-primary-500 to-primary-600 mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {STATS.map((stat, index) => (
          <div
            class="group relative bg-white rounded-2xl p-8 lg:p-10 shadow-lg hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-primary-200 hover:-translate-y-2"
            data-animate
            data-stat-index={index}
          >
            <!-- Gradient overlay on hover -->
            <div class="absolute inset-0 bg-gradient-to-br from-primary-50/0 to-primary-100/0 group-hover:from-primary-50/50 group-hover:to-primary-100/30 rounded-2xl transition-all duration-500 pointer-events-none"></div>
            
            <div class="relative z-10">
              <!-- Icon placeholder -->
              <div class="w-16 h-16 bg-gradient-to-br from-primary-400 to-primary-600 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              </div>

              <div
                class="text-5xl sm:text-6xl lg:text-7xl font-bold bg-gradient-to-r from-primary-500 to-primary-600 bg-clip-text text-transparent mb-6"
                data-counter
                data-target={stat.value}
                data-prefix={stat.prefix || ''}
                data-suffix={stat.suffix}
              >
                {stat.prefix || ''}{stat.value}{stat.suffix}
              </div>
              
              <p class="text-gray-600 text-base lg:text-lg mb-6 leading-relaxed min-h-[3rem]">
                {stat.label}
              </p>
              
              <div class="pt-6 border-t border-gray-100">
                <p class="text-brand-dark-purple font-bold text-lg lg:text-xl">
                  {stat.commitment}
                </p>
              </div>
            </div>

            <!-- Decorative corner accent -->
            <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-primary-500/10 to-transparent rounded-bl-3xl pointer-events-none"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { animateCounter } from '@/utils/animations';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    // Animate counters when they come into view
    document.querySelectorAll('[data-counter]').forEach((element) => {
      const target = parseInt(element.getAttribute('data-target') || '0');
      const prefix = element.getAttribute('data-prefix') || '';
      const suffix = element.getAttribute('data-suffix') || '';

      ScrollTrigger.create({
        trigger: element,
        start: 'top 80%',
        onEnter: () => {
          animateCounter(element as HTMLElement, target, 2, prefix, suffix);
        },
        once: true,
      });
    });
  }
</script>
