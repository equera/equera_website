---

let calendlyUrl = "https://calendly.com/danielle-equera/30min";
---

<section
  id="cta"
  class="relative py-20 lg:py-28 bg-gradient-to-br from-primary-50 via-white to-accent-blue/5 overflow-hidden"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-7xl mx-auto">
      <div class="relative bg-gradient-to-br from-primary-50 via-white to-accent-blue/5 rounded-3xl p-8 lg:p-12 border border-primary-100 shadow-2xl overflow-hidden" data-animate>
        <!-- Background image -->
        <div class="absolute inset-0 opacity-10">
          <img
            src="/images/equera-cta-bg.webp"
            alt=""
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
    
        <div class="max-w-4xl mx-auto text-center mb-12 lg:mb-16" data-animate>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark-purple mb-4">
            Ready to Join the Movement?
          </h2>
        </div>

        <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          <!-- CBT Organizations -->
          <div
            class="bg-white/90 backdrop-blur-sm rounded-2xl p-6 lg:p-7 shadow-lg border border-gray-100 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 flex flex-col"
            data-animate
          >
            <div class="flex-1">
              <h3 class="text-xl lg:text-2xl font-bold text-primary-500 mb-3">
                CBT Organizations
              </h3>
              <p class="text-gray-700 text-sm lg:text-base">
                Take your community tourism global.
              </p>
            </div>
            <div class="mt-6">
              <a
                href="/contact"
                class="inline-flex items-center justify-center w-full px-4 py-3 text-sm font-semibold rounded-xl bg-brand-dark-purple text-white hover:bg-black transition-colors duration-200 shadow-md hover:shadow-lg"
              >
                Join Our Network
                <span class="ml-1">→</span>
              </a>
            </div>
          </div>

          <!-- Tour Operators & Travel Agencies -->
          <div
            class="bg-white/90 backdrop-blur-sm rounded-2xl p-6 lg:p-7 shadow-lg border border-gray-100 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 flex flex-col"
            data-animate
          >
            <div class="flex-1">
              <h3 class="text-xl lg:text-2xl font-bold text-primary-500 mb-3">
                Tour Operators &amp; Travel Agencies
              </h3>
              <p class="text-gray-700 text-sm lg:text-base">
                Source authentic experiences, or deploy our tech to run your own supply chain.
              </p>
            </div>
            <div class="mt-6">
              <a
                href={calendlyUrl}
                class="inline-flex items-center justify-center w-full px-4 py-3 text-sm font-semibold rounded-xl bg-primary-500 text-white hover:bg-primary-600 transition-colors duration-200 shadow-md hover:shadow-lg"
                target="_blank"
                >
                Book a Demo
                <span class="ml-1">→</span>
              </a>
            </div>
          </div>

          <!-- Tourism Boards & Partners -->
          <div
            class="bg-white/90 backdrop-blur-sm rounded-2xl p-6 lg:p-7 shadow-lg border border-gray-100 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 flex flex-col"
            data-animate
          >
            <div class="flex-1">
              <h3 class="text-xl lg:text-2xl font-bold text-primary-500 mb-3">
                Tourism Boards &amp; Partners
              </h3>
              <p class="text-gray-700 text-sm lg:text-base">
                Scale community tourism across your destination.
              </p>
            </div>
            <div class="mt-6">
              <a
                href="/contact"
                class="inline-flex items-center justify-center w-full px-4 py-3 text-sm font-semibold rounded-xl bg-brand-dark-purple text-white hover:bg-black transition-colors duration-200 shadow-md hover:shadow-lg"
              >
                Let's Talk
                <span class="ml-1">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

