---
import { FEATURES } from '@/config/site';
---

<section
  id="features"
  class="relative py-20 lg:py-32 bg-gradient-to-b from-gray-50 to-white overflow-hidden"
>
  <!-- Background decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-100/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-accent-blue/10 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 lg:mb-20" data-animate>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-brand-dark-purple mb-4">
          Features
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-primary-500 to-primary-600 mx-auto rounded-full"></div>
      </div>

      <!-- Screenshots showcase -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16" data-animate>
        <div class="relative group">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl transform group-hover:scale-[1.02] transition-transform duration-500">
            <img
              src="/images/equera-screenshot1.avif"
              alt="Equera platform screenshot"
              class="w-full h-auto object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
          </div>
        </div>
        <div class="relative group">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl transform group-hover:scale-[1.02] transition-transform duration-500">
            <img
              src="/images/equera-screenshot2.avif"
              alt="Equera platform screenshot"
              class="w-full h-auto object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
          </div>
        </div>
      </div>

      <!-- Feature cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {FEATURES.map((feature, index) => (
          <div
            class="group relative bg-white/80 backdrop-blur-sm rounded-2xl p-6 lg:p-8 border border-gray-200/50 hover:border-primary-300 shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2"
            data-animate
            data-feature-index={index}
          >
            <!-- Glassmorphism effect -->
            <div class="absolute inset-0 bg-gradient-to-br from-white/50 to-white/30 backdrop-blur-md rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            
            <!-- Gradient border on hover -->
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-primary-500/0 to-primary-600/0 group-hover:from-primary-500/20 group-hover:to-primary-600/10 transition-all duration-500 pointer-events-none"></div>

            <div class="relative z-10">
              <!-- Icon -->
              <div class="w-14 h-14 bg-gradient-to-br from-primary-400 to-primary-600 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300 shadow-lg">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>

              <h3 class="text-xl lg:text-2xl font-bold text-brand-dark-purple mb-4 group-hover:text-primary-600 transition-colors">
                {feature.title}
              </h3>
              <p class="text-gray-600 leading-relaxed">
                {feature.description}
              </p>
            </div>

            <!-- Decorative corner -->
            <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-primary-500/10 to-transparent rounded-bl-3xl pointer-events-none"></div>
          </div>
        ))}
      </div>

      <!-- Launch/Pilot Section -->
      <div class="mt-20 lg:mt-32" data-animate>
        <div class="relative bg-gradient-to-br from-primary-50 via-white to-accent-blue/5 rounded-3xl p-8 lg:p-12 border border-primary-100 shadow-2xl overflow-hidden">
          <!-- Background image -->
          <div class="absolute inset-0 opacity-10">
            <img
              src="/images/equera-launch.avif"
              alt="Equera launch"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <div class="relative z-10">
            <div class="text-center mb-8">
              <div class="inline-block bg-gradient-to-r from-primary-500 to-primary-600 text-white font-bold text-sm uppercase tracking-wider px-6 py-2 rounded-full shadow-lg mb-6">
                WE'RE LIVE!
              </div>
              <h3 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark-purple mb-6">
                First Pilot Underway
              </h3>
            </div>

            <div class="max-w-3xl mx-auto text-center space-y-6">
              <p class="text-gray-700 text-lg lg:text-xl leading-relaxed">
                In September, we launched our first pilot with <strong class="text-brand-dark-purple">over 60 customers</strong> across three countries. We're working with them to ensure Equera truly meets the needs of CBTOs around the world.
              </p>
              
              <p class="text-brand-dark-purple font-semibold text-lg lg:text-xl">
                Reach out to us! Use the contact form on our website or connect over social media, and we'll be sure to get in touch with you.
              </p>

              <div class="pt-6">
                <a
                  href="/contact"
                  class="inline-flex items-center px-8 py-4 bg-primary-500 text-white font-semibold rounded-xl hover:bg-primary-600 transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-primary-500/50 transform hover:-translate-y-1"
                >
                  Get in Touch
                  <svg
                    class="ml-2 w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 7l5 5m0 0l-5 5m5-5H6"
                    />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
