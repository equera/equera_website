---
---

<section
  id="features"
  class="relative py-20 lg:py-32 bg-gradient-to-b from-gray-50 to-white overflow-hidden"
>
  <!-- Background decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-100/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-accent-blue/10 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 lg:mb-20" data-animate>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark-purple mb-4">
          The Missing Infrastructure Layer
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-primary-500 to-primary-600 mx-auto rounded-full"></div>
      </div>

      <!-- Content + screenshots split layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <!-- Features list (left) -->
        <div class="space-y-6 text-lg text-gray-700 leading-relaxed" data-animate>
          <div>
            <h3 class="text-xl lg:text-2xl font-bold text-primary-500 mb-1">
              Effortless Onboarding
            </h3>
            <p>
              Digitize offline supply at scale - from remote communities to your platform in days, not months
            </p>
          </div>

          <div>
            <h3 class="text-xl lg:text-2xl font-bold text-primary-500 mb-1">
              Multi-Channel Distribution
            </h3>
            <p>
              Connect to global travel demand through direct bookings, tour operators, and preferred DMC partnerships
            </p>
          </div>

          <div>
            <h3 class="text-xl lg:text-2xl font-bold text-primary-500 mb-1">
              WhatsApp-Based Automation
            </h3>
            <p>
              Convert inquiries into bookings, and manage guest communication through tools communities already use
            </p>
          </div>

          <div>
            <h3 class="text-xl lg:text-2xl font-bold text-primary-500 mb-1">
              Centralized Operations
            </h3>
            <p>
              Manage all product types - experiences, packages, accommodations - from one unified platform
            </p>
          </div>

          <div>
            <h3 class="text-xl lg:text-2xl font-bold text-primary-500 mb-1">
              Real-Time Impact
            </h3>
            <p>
              Track and manage the true impact your travel is having on your community
            </p>
          </div>
        </div>

        <!-- Screenshots (right): three phone-like cards, inspired by reference image -->
        <div class="flex justify-center items-end self-center gap-3 sm:gap-4 lg:gap-6" data-animate>
          <!-- Left card -->
          <div class="hidden sm:block relative max-w-[220px] aspect-[9/16] rounded-3xl overflow-hidden transform -rotate-12 translate-y-4 -z-10">
            <img
              src="/images/equera-screenshot2.webp"
              alt="Equera platform - operations view"
              class="w-full h-full"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/25 via-transparent to-transparent"></div>
          </div>

          <!-- Center card -->
          <div class="relative max-w-[220px] sm:max-w-[260px] aspect-[9/16] rounded-3xl overflow-hidden">
            <img
              src="/images/equera-screenshot1.webp"
              alt="Equera platform screenshot"
              class="w-full h-full"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
          </div>

          <!-- Right card -->
          <div class="hidden sm:block relative max-w-[220px] aspect-[9/16] rounded-3xl overflow-hidden transform rotate-12 translate-y-4 -z-10">
            <img
              src="/images/equera-screenshot2.webp"
              alt="Equera platform - analytics view"
              class="w-full h-full"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/25 via-transparent to-transparent"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
