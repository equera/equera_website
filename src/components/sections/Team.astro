const team = [
  {
    name: 'Danielle Finch',
    role: 'Co-founder & CEO',
    bio: '14 years scaling tech across 170 countries (GE, Michelin, HomeToGo). Built the first prototype solo, then found the right team to make it real.',
    fun: "Also: I'm the team's unofficial cameraman and have been known to misplace my side bag on several community visits",
  },
  {
    name: 'Rogers Nasasira',
    role: 'Business Operations Lead',
    bio: '7 years leading travel operations in Uganda. Former member of Travolution global CBTO network. The team\'s driver—literally and figuratively.',
    fun: "I've navigated potholes, elephants on the road, and am the team's official Herdsman",
  },
  {
    name: 'Sabiiti Fenekansi',
    role: 'Training Manager',
    bio: 'Founder of Kitara Foundation for Regional Tourism. 10 years developing sustainable tourism curriculum. Found through a Google search (yes, really).',
    fun: "I'm the team storyteller who has a passion for hiking, working with communities, and making connections everywhere we go",
  },
];
---

<section
  id="team"
  class="relative py-20 lg:py-32 bg-white overflow-hidden"
>
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-primary-100/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-0 w-80 h-80 bg-accent-blue/10 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 lg:mb-20" data-animate>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark-purple mb-4">
          Meet the Team
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-primary-500 to-primary-600 mx-auto rounded-full"></div>
      </div>

      <!-- Story: How a Google Maps accident became a mission (with team photo) -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-center mb-16 lg:mb-20" data-animate>
        <div class="order-2 lg:order-1">
          <h3 class="text-2xl lg:text-3xl font-bold text-brand-dark-purple mb-6">
            How a Google Maps accident became a mission
          </h3>
          <div class="space-y-5 text-lg text-gray-700 leading-relaxed">
            <p>
              In 2024, <strong class="text-brand-dark-purple">Danielle</strong> stumbled upon a community-based tourism organization on Google Maps during a trip through Malaysian Borneo. Despite years working in travel tech and traveling the world, she'd never heard the term "community-based tourism" before. That accidental stay became the best travel experience of her life.
            </p>
            <p>
              She went down the rabbit hole—literally googling "what is community-based tourism"—and realized just how overlooked these organizations are in the industry. She quit her job and never looked back.
            </p>
            <p>
              Fast forward to 2025. Armed with a conference ticket and a prototype, Danielle landed in Entebbe for POATE. There, she met <strong class="text-brand-dark-purple">Rogers</strong>—connected through a mutual contact—who brought 7 years of leading travel operations in Uganda. She also found <strong class="text-brand-dark-purple">Sabiiti</strong> through a random Google search. What started as a one-day meetup turned into a multi-day road trip, and the decision to form a team and launch our pilot.
            </p>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div class="relative rounded-2xl overflow-hidden shadow-xl ring-1 ring-black/5">
            <img
              src="/images/equera-team1.webp"
              alt="Equera team"
              class="w-full aspect-[4/3] object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      <!-- Team member cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10 mb-16 lg:mb-20">
        {team.map((member, index) => (
          <div
            class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-100 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col"
            data-animate
          >
            <h4 class="text-xl font-bold text-brand-dark-purple mb-1">
              {member.name}
            </h4>
            <p class="text-primary-500 font-semibold text-sm mb-4">
              {member.role}
            </p>
            <p class="text-gray-700 text-sm lg:text-base leading-relaxed flex-1 mb-4">
              {member.bio}
            </p>
            <p class="text-gray-500 text-sm italic border-l-2 border-primary-200 pl-3">
              {member.fun}
            </p>
          </div>
        ))}
      </div>

      <!-- Mission closing -->
      <div class="max-w-4xl mx-auto text-center" data-animate>
        <p class="text-lg lg:text-xl text-gray-700 leading-relaxed">
          We span inbound and outbound markets, tech and tourism, two continents. United by one mission: <strong class="text-brand-dark-purple">to restore equity in travel by building infrastructure that works for everyone, not just the 1%.</strong>
        </p>
      </div>

      <!-- Optional: image strip from founder assets -->
      <!-- <div class="mt-16 grid grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto" data-animate>
        {teamImages.map((image, index) => (
          <div class="relative overflow-hidden rounded-xl shadow-lg aspect-[4/3]">
            <img
              src={image}
              alt={`Equera team and journey ${index + 1}`}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        ))}
      </div> -->
    </div>
  </div>
</section>
