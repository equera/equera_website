---
---

<section
  id="launch"
  class="relative py-20 lg:py-32 bg-gradient-to-br from-primary-50 via-white to-accent-blue/5 overflow-hidden"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-7xl mx-auto">
      <div class="relative bg-gradient-to-br from-primary-50 via-white to-accent-blue/5 rounded-3xl p-8 lg:p-12 border border-primary-100 shadow-2xl overflow-hidden" data-animate>
        <!-- Background image -->
        <div class="absolute inset-0 opacity-10">
          <img
            src="/images/equera-launch.avif"
            alt="Equera launch"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>

        <div class="relative z-10">
          <div class="text-center mb-8">
            <div class="inline-block bg-gradient-to-r from-primary-500 to-primary-600 text-white font-bold text-sm uppercase tracking-wider px-6 py-2 rounded-full shadow-lg mb-6">
              WE'RE LIVE!
            </div>
            <h3 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark-purple mb-6">
              First Pilot Underway
            </h3>
          </div>

          <div class="max-w-3xl mx-auto text-center space-y-6">
            <p class="text-gray-700 text-lg lg:text-xl leading-relaxed">
              In September, we launched our first pilot with <strong class="text-brand-dark-purple">over 60 customers</strong> across three countries. We're working with them to ensure Equera truly meets the needs of CBTOs around the world.
            </p>
            
            <p class="text-brand-dark-purple font-semibold text-lg lg:text-xl">
              Reach out to us! Use the contact form on our website or connect over social media, and we'll be sure to get in touch with you.
            </p>

            <div class="pt-6">
              <a
                href="/contact"
                class="inline-flex items-center px-8 py-4 bg-primary-500 text-white font-semibold rounded-xl hover:bg-primary-600 transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-primary-500/50 transform hover:-translate-y-1"
              >
                Get in Touch
                <svg
                  class="ml-2 w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 7l5 5m0 0l-5 5m5-5H6"
                  />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

