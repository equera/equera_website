---
---

<section
  id="solution"
  class="relative py-20 lg:py-32 bg-white overflow-hidden"
>
  <!-- Background decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-0 w-96 h-96 bg-primary-100/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-0 w-80 h-80 bg-accent-blue/10 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 lg:mb-20" data-animate>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-brand-dark-purple mb-4">
          THE SOLUTION
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-primary-500 to-primary-600 mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Image Side -->
        <div class="order-2 lg:order-1" data-animate>
          <div class="relative">
            <div class="relative rounded-3xl overflow-hidden shadow-2xl transform hover:scale-[1.02] transition-transform duration-500">
              <img
                src="/images/equera-solution.avif"
                alt="Equera platform solution for community-based tourism"
                class="w-full h-auto object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
            </div>
            
            <!-- Decorative elements -->
            <div class="absolute -top-6 -left-6 w-32 h-32 bg-primary-400/30 rounded-full blur-2xl -z-10"></div>
            <div class="absolute -bottom-6 -right-6 w-40 h-40 bg-accent-blue/20 rounded-full blur-2xl -z-10"></div>
          </div>
        </div>

        <!-- Content Side -->
        <div class="order-1 lg:order-2" data-animate>
          <div class="mb-8">
            <h3 class="text-5xl sm:text-6xl lg:text-7xl font-bold bg-gradient-to-r from-primary-500 to-primary-600 bg-clip-text text-transparent mb-8">
              Equera
            </h3>
          </div>

          <div class="space-y-6 text-lg text-gray-700 leading-relaxed">
            <p>
              Equera is a B2B SaaS connectivity platform that will <strong class="text-brand-dark-purple">radically change the economics</strong> of the tourism industry, by bringing authentic, sustainable travel online.
            </p>
            
            <p>
              Today's traveler demands authentic, sustainable travel products - exactly what community based tourism offers. This model of tourism has been around since the 1970s, but remains <strong class="text-brand-dark-purple">largely offline</strong>.
            </p>
            
            <div class="bg-gradient-to-r from-primary-50 to-primary-100/50 rounded-2xl p-6 border-l-4 border-primary-500">
              <p class="text-brand-dark-purple font-bold text-xl mb-2">
                Equera changes that.
              </p>
            </div>
            
            <p>
              Built for and with input from local communities, Equera is the first platform to combine <strong class="text-brand-dark-purple">multi-product, multi-channel distribution</strong> with product and business development tools. Built with extensive customer feedback and specifically for low-bandwidth, rural environments, Equera delivers what CBTOs need to compete on the global market.
            </p>
          </div>

          <!-- CTA -->
          <div class="mt-10">
            <a
              href="#features"
              class="inline-flex items-center px-8 py-4 bg-primary-500 text-white font-semibold rounded-xl hover:bg-primary-600 transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-primary-500/50 transform hover:-translate-y-1"
            >
              Explore Features
              <svg
                class="ml-2 w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"
                />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
