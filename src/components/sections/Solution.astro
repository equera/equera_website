---
const capabilities = [
  { lead: 'Deploy our infrastructure', rest: ' to digitize and scale your own supply chain' },
  { lead: 'Launch with supply', rest: " you couldn't source on your own" },
  { lead: 'Replace spreadsheets and WhatsApp chaos', rest: ' with one AI that runs your operations' },
  { lead: 'Auto-generate impact reports', rest: ' as bookings come in' },
  { lead: 'Give your local suppliers the tools', rest: ' to grow their digital skills and their quality of service' },
];
---

<section id="solution" class="relative py-20 xl:py-24 bg-white overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12 lg:mb-14" data-animate>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark-purple mb-4">
          Operators &amp; Destinations
        </h2>
        <p class="text-primary-600 font-semibold text-lg lg:text-xl mb-4">
          Your Supply, Our Tech
        </p>
        <div class="w-24 h-0.5 bg-primary-500 mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-x-14 items-stretch">
        <!-- Capability ledger (left) -->
        <div
          class="lg:col-span-5 border-y border-brand-dark-purple/10 divide-y divide-brand-dark-purple/10 flex flex-col lg:grid lg:grid-rows-5"
          data-animate
        >
          {capabilities.map((cap) => (
            <div class="group grid grid-cols-[2.5rem_1fr] gap-4 items-center py-5 lg:py-4 px-3 -mx-3 rounded-xl transition-colors duration-200 hover:bg-brand-dark-purple/[0.04]">
              <img
                src="/images/equera-mark.webp"
                alt=""
                class="w-6 h-6 transition-transform duration-200 group-hover:scale-110"
                loading="lazy"
              />
              <p class="font-body text-base lg:text-lg leading-relaxed text-brand-dark-purple/75">
                <span class="font-display font-semibold text-brand-dark-purple">{cap.lead}</span>{cap.rest}
              </p>
            </div>
          ))}
        </div>

        <!-- Product proof (right): layered laptops -->
        <div class="lg:col-span-7 self-center relative" data-animate>
          <img
            src="/images/equera-operator-ai.webp"
            alt="Equera AI Operator answering a sourcing question in the operator portal"
            class="w-[82%] ml-auto h-auto"
            loading="lazy"
          />
          <img
            src="/images/equera-operator-impact.webp"
            alt="Equera community impact report with income and allocation breakdown"
            class="relative z-10 w-[88%] h-auto -mt-[34%] drop-shadow-2xl"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
