---
---

<section
  id="solution"
  class="relative py-20 lg:py-32 bg-white overflow-hidden"
>
  <!-- Background decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-0 w-96 h-96 bg-primary-100/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-0 w-80 h-80 bg-accent-blue/10 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 lg:mb-20" data-animate>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark-purple mb-4">
          Rebuilding Travel from the Bottom Up
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-primary-500 to-primary-600 mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Image Side -->
        <div class="order-2 lg:order-1 md:max-w-sm lg:max-w-sm xl:max-w-md mx-auto" data-animate>
          <div class="relative">
            <div class="relative rounded-3xl overflow-hidden shadow-2xl transform hover:scale-[1.02] transition-transform duration-500">
              <img
                src="/images/equera-solution.avif"
                alt="Equera platform solution for community-based tourism"
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
            </div>
            
            <!-- Decorative elements -->
            <div class="absolute -top-6 -left-6 w-32 h-32 bg-primary-400/30 rounded-full blur-2xl -z-10"></div>
            <div class="absolute -bottom-6 -right-6 w-40 h-40 bg-accent-blue/20 rounded-full blur-2xl -z-10"></div>
          </div>
        </div>

        <!-- Content Side -->
        <div class="order-1 lg:order-2" data-animate>
          <div class="space-y-8">
            <!-- Block 1 -->
            <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-6 lg:p-8 border border-gray-200 shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
              <!-- <p class="text-xs font-semibold tracking-[0.2em] uppercase text-primary-500 mb-3">
                Block 1
              </p> -->
              <h3 class="text-2xl lg:text-3xl font-bold text-brand-dark-purple mb-2">
                Travel Agencies, Tour Operators and Lodges
              </h3>
              <p class="text-primary-600 font-semibold mb-4">
                Access Authentic Supply
              </p>
              <p class="text-gray-700 leading-relaxed">
                Source vetted community-experiences directly – or work with your existing DMC partners on our platform.
              </p>
            </div>

            <!-- Block 2 -->
            <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-6 lg:p-8 border border-gray-200 shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
              <!-- <p class="text-xs font-semibold tracking-[0.2em] uppercase text-primary-500 mb-3">
                Block 2
              </p> -->
              <h3 class="text-2xl lg:text-3xl font-bold text-brand-dark-purple mb-2">
                DMCs &amp; Ground Handlers
              </h3>
              <p class="text-primary-600 font-semibold mb-4">
                Power Your Sourcing
              </p>
              <p class="text-gray-700 leading-relaxed">
                Access vetted CBT supply and become a preferred distribution partner for authentic experiences.
              </p>
            </div>

            <!-- Block 3 -->
            <div class="bg-white/90 backdrop-blur-sm rounded-2xl p-6 lg:p-8 border border-gray-200 shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
              <!-- <p class="text-xs font-semibold tracking-[0.2em] uppercase text-primary-500 mb-3">
                Block 3
              </p> -->
              <h3 class="text-2xl lg:text-3xl font-bold text-brand-dark-purple mb-2">
                Community-based tourism organizations
              </h3>
              <p class="text-primary-600 font-semibold mb-4">
                Go Global, Stay Local
              </p>
              <p class="text-gray-700 leading-relaxed">
                Digitize your products and access worldwide distribution without losing control of your operations.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
