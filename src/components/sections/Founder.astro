---
import { SITE } from '@/config/site';

const founderImages = [
  '/images/equera-founder1.avif',
  '/images/equera-founder2.avif',
  '/images/equera-founder3.avif',
  '/images/equera-founder4.avif',
];
---

<section
  id="founder"
  class="relative py-20 lg:py-32 bg-white overflow-hidden"
>
  <!-- Background decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-primary-100/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-0 w-80 h-80 bg-accent-blue/10 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 lg:mb-20" data-animate>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark-purple mb-4">
          Meet the Founder
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-primary-500 to-primary-600 mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <!-- Image Gallery -->
        <div class="order-2 lg:order-1" data-animate>
          <div class="grid grid-cols-2 gap-4">
            {founderImages.map((image, index) => (
              <div
                class={`relative group overflow-hidden rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 ${
                  index === 0 ? 'col-span-2 h-64' : 'h-48'
                } ${index === 2 ? 'h-56' : ''}`}
              >
                <img
                  src={image}
                  alt={`Danielle Finch - Founder of Equera ${index + 1}`}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  loading={index < 2 ? 'eager' : 'lazy'}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              </div>
            ))}
          </div>
        </div>

        <!-- Content -->
        <div class="order-1 lg:order-2" data-animate>
          <div class="space-y-6 text-lg text-gray-700 leading-relaxed">
            <p>
              The seed for Equera was planted in a Michigan classroom in 1997, when a young <strong class="text-brand-dark-purple">Danielle Finch</strong> first learned about Kenya. Captivated by the idea of experiencing life in a different way, she promised herself one day she would go. In 2011, she did - and it changed everything.
            </p>
            
            <p>
              What was meant to be a bucket-list trip turned into a lifelong passion. Since then, Danielle has explored <strong class="text-brand-dark-purple">60 countries</strong>, lived abroad, and built a successful career in digital transformation and customer experience. Along the way, her deep-rooted commitment to equity only grew stronger.
            </p>
            
            <div class="bg-gradient-to-r from-primary-50 to-primary-100/50 rounded-2xl p-6 border-l-4 border-primary-500">
              <p class="text-gray-700 leading-relaxed">
                In 2024, she made another bold move: leaving corporate life to launch <strong class="text-brand-dark-purple">Equera</strong> - a mission-driven venture to capture a new wave of tourism demand with equity, access, and authentic connection.
              </p>
            </div>
            
            <p>
              Danielle is based in Berlin, but currently traveling through <strong class="text-brand-dark-purple">Southeast Asia, East Africa and Central America</strong>, to develop Equera with input from local and community based tourism organizations around the world. She's backed by the <strong class="text-brand-dark-purple">Grace Berlin Accelerator program</strong>, Germany's leading accelerator for women.
            </p>
          </div>

          <!-- Podcast Links -->
          <div class="mt-8 bg-white rounded-2xl p-6 border border-gray-200 shadow-lg">
            <p class="text-brand-dark-purple font-semibold text-lg mb-4">To learn more about Danielle and Equera, check out these podcasts:</p>
            <div class="space-y-3">
              <a
                href="#"
                class="block p-4 bg-gray-50 hover:bg-primary-50 rounded-xl border border-gray-200 hover:border-primary-300 transition-all duration-300 group"
              >
                <p class="text-primary-600 group-hover:text-primary-700 font-medium">
                  Travel Tomorrow: Community Based Tourism with Danielle Finch
                </p>
              </a>
              <a
                href="#"
                class="block p-4 bg-gray-50 hover:bg-primary-50 rounded-xl border border-gray-200 hover:border-primary-300 transition-all duration-300 group"
              >
                <p class="text-primary-600 group-hover:text-primary-700 font-medium">
                  Founders Hub: How your travel effects local communities
                </p>
              </a>
            </div>
          </div>

          <!-- Follow Journey -->
          <div class="mt-10">
            <h3 class="text-2xl lg:text-3xl font-bold text-brand-dark-purple mb-4">Follow the Journey</h3>
            <p class="text-gray-700 text-lg mb-6 leading-relaxed">
              Building Equera means stepping out from behind the screen. We're currently on the ground with current and future customers, experiencing their products, getting their feedback, and shaping a tool that truly fits their world.
            </p>
            <a
              href={SITE.links.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-primary-500 to-primary-600 text-white font-semibold rounded-xl hover:from-primary-600 hover:to-primary-700 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1"
            >
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
              </svg>
              @danielle_in_de
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
