---
import { SITE } from '@/config/site';
import Logo from '@/components/ui/Logo.astro';
---

<section
  id="home"
  class="relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-gray-50 via-white to-primary-50/30"
>
  <!-- Background decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 bg-primary-200/20 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent-blue/10 rounded-full blur-3xl animate-float" style="animation-delay: 2s;"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Content Side -->
      <div class="order-2 lg:order-1" data-animate>
        <!-- <div class="mb-6">
          <Logo size="lg" class="mb-8" />
        </div> -->
        
        <h2 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-brand-dark-purple mb-6 leading-[1.1] tracking-tight">
          <span class="block bg-gradient-to-r from-primary-500 to-primary-600 bg-clip-text text-transparent">
            Infrastructure for the social tourism revolution
          </span>
        </h2>

        <p class="text-xl text-gray-600 mb-8 leading-relaxed max-w-lg">
          Radically changing the economics of local and community based tourism through innovative technology.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a
            href="/contact"
            class="group inline-flex items-center justify-center px-8 py-4 bg-primary-500 text-white font-semibold rounded-xl hover:bg-primary-600 transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-primary-500/50 transform hover:-translate-y-1"
          >
            Contact Us
            <svg
              class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"
              />
            </svg>
          </a>
          <a
            href="#solution"
            class="inline-flex items-center justify-center px-8 py-4 bg-white text-gray-900 font-semibold rounded-xl border-2 border-gray-200 hover:border-primary-500 transition-all duration-300 shadow-md hover:shadow-lg"
          >
            Learn More
          </a>
        </div>

        <div class="flex items-center gap-6">
          <p class="text-gray-500 text-sm">Connect with us</p>
          <div class="flex items-center gap-4">
            <a
              href={SITE.links.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-100 hover:bg-primary-500 hover:text-white transition-all duration-300 group"
              aria-label="LinkedIn"
            >
              <svg class="w-5 h-5 text-gray-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                />
              </svg>
            </a>
            <a
              href={SITE.links.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-100 hover:bg-primary-500 hover:text-white transition-all duration-300 group"
              aria-label="Instagram"
            >
              <svg class="w-5 h-5 text-gray-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Images Side: one dominant + overlapping cards (restrained) -->
      <div class="order-1 lg:order-2 relative" data-animate>
        <div class="relative max-w-xl mx-auto lg:max-w-none">
          <!-- Main image -->
          <div class="relative rounded-3xl overflow-hidden shadow-2xl transform hover:scale-[1.02] transition-transform duration-500">
            <img
              src="/images/equera-hero1.jpeg"
              alt="Equera platform showcasing community-based tourism"
              class="w-full h-auto object-cover aspect-[4/3]"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
          </div>

          <!-- Overlapping card - bottom right -->
          <div
            class="absolute -bottom-6 -right-4 lg:-right-6 w-44 h-44 lg:w-52 lg:h-52 rounded-2xl overflow-hidden shadow-xl border-4 border-white transform rotate-6 hover:rotate-3 transition-transform duration-300 z-10"
            data-parallax
          >
            <img
              src="/images/equera-hero2.jpeg"
              alt="Community-based tourism experience"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Overlapping card - bottom left (new) -->
          <div class="absolute -bottom-4 -left-2 lg:-left-4 w-36 h-36 lg:w-40 lg:h-40 rounded-xl overflow-hidden shadow-lg border-4 border-white transform -rotate-3 hover:rotate-0 transition-transform duration-300 z-10">
            <img
              src="/images/equera-hero3.webp"
              alt="Community-based tourism"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Small accent - top right (new) -->
          <div class="absolute -top-3 -right-2 lg:top-4 lg:right-4 w-36 h-36 lg:w-40 lg:h-40 rounded-xl overflow-hidden shadow-md border-2 border-white transform rotate-12 hover:rotate-6 transition-transform duration-300 z-10 opacity-95">
            <img
              src="/images/equera-hero4.webp"
              alt="Travel and community"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Small accent - top left (new) -->
          <div class="absolute top-2 -left-1 lg:top-6 lg:-left-2 w-40 h-40 lg:w-50 lg:h-50 rounded-lg overflow-hidden shadow-md border-2 border-white transform -rotate-12 hover:-rotate-6 transition-transform duration-300 z-10 opacity-95">
            <img
              src="/images/equera-hero5.jpeg"
              alt="Equera community"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Decorative blur (keep subtle) -->
          <div class="absolute -top-6 -left-6 w-32 h-32 bg-primary-400/20 rounded-full blur-2xl -z-10"></div>
          <div class="absolute -bottom-12 -right-12 w-40 h-40 bg-brand-blue-purple/10 rounded-full blur-2xl -z-10"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce hidden lg:block">
    <div class="w-6 h-10 border-2 border-gray-400 rounded-full flex items-start justify-center p-2">
      <div class="w-1 h-3 bg-gray-400 rounded-full animate-pulse"></div>
    </div>
  </div>
</section>

<script>
  // Parallax effect for secondary image
  if (typeof window !== 'undefined') {
    const parallaxElement = document.querySelector('[data-parallax]');
    if (parallaxElement) {
      window.addEventListener('scroll', () => {
        const scrolled = window.pageYOffset;
        const rate = scrolled * 0.2;
        (parallaxElement as HTMLElement).style.transform = `translateY(${rate}px) rotate(6deg)`;
      });
    }
  }
</script>
